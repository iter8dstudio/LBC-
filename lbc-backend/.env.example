# LBC Backend Environment Configuration Template
# Copy this file to .env and fill in with your actual values
# NEVER commit the .env file to Git - it contains sensitive secrets!
# This file (.env.example) is safe to commit and serves as documentation

# ============================================================
# DATABASE (Critical)
# ============================================================
# PostgreSQL connection string
# For Railway: Copy from Railway PostgreSQL plugin
# For local: postgresql://postgres:password@localhost:5432/lbc
DATABASE_URL=postgresql://user:password@localhost:5432/lbc

# ============================================================
# FRONTEND URLS (Configuration)
# ============================================================
# Local/development frontend URL
FRONTEND_URL=http://localhost:3000

# Production frontend URL (for CORS whitelisting)
FRONTEND_URL_PROD=https://yourdomain.com

# ============================================================
# JWT SECRETS (CRITICAL - DO NOT SHARE)
# ============================================================
# Minimum 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ACCESS_TOKEN_SECRET=your-secret-key-here-min-32-chars-base64-encoded

# Minimum 32 characters. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
REFRESH_TOKEN_SECRET=your-refresh-secret-key-here-min-32-chars

# JWT token expiration times
# SECURITY: Keep access token short-lived; refresh token handles long sessions
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# CLOUDINARY (Image Management)
# ============================================================
# Sign up: https://cloudinary.com
# Get from: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_NAME=your_cloudinary_name

CLOUDINARY_API_KEY=your_api_key

# SENSITIVE: The API secret - never share or commit
CLOUDINARY_API_SECRET=your_api_secret

# Upload folder for organizing images
CLOUDINARY_UPLOAD_FOLDER=lbc

# ============================================================
# PAYSTACK (Payment Processing)
# ============================================================
# Get from: https://dashboard.paystack.co → API Keys & Webhooks
# IMPORTANT: Use pk_live_ and sk_live_ for production (not pk_test_)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# SENSITIVE: The secret key - never share or commit
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# ⚠️ There is NO separate webhook secret for Paystack.
# Webhook signature verification uses PAYSTACK_SECRET_KEY (above) via HMAC-SHA512.
# Do not add a PAYSTACK_WEBHOOK_SECRET variable — it would be unused and misleading.

# ============================================================
# EMAIL (Nodemailer Configuration)
# ============================================================
# SMTP host for your email provider
# Gmail: smtp.gmail.com
# SendGrid: smtp.sendgrid.net
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
EMAIL_PORT=587

# Email address to send from
# For Gmail: use your Gmail address
EMAIL_USER=your-email@gmail.com

# SENSITIVE: Email password or app-specific password - never share or commit
# For Gmail: Use App-Specific Password from Google Account Security settings
EMAIL_PASS=your-app-specific-password-or-email-password

# Display name for outgoing emails
EMAIL_FROM=noreply@yourdomain.com

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Server port (Railway will override with $PORT)
PORT=5000

# Environment: development, staging, or production
# Set to 'production' for production deployments
NODE_ENV=development

# ============================================================
# NOTES & SECURITY
# ============================================================
# 1. SENSITIVE VALUES:
#    - Never commit .env to Git
#    - Never share secrets via email or chat
#    - Rotate secrets quarterly
#    - Use strong random values (32+ characters)
#
# 2. DEVELOPMENT vs PRODUCTION:
#    - Development: Use test/local values
#    - Production: Use live credentials only (Paystack pk_live_, sk_live_)
#
# 3. FOR RAILWAY DEPLOYMENT:
#    - Add these variables to Railway Dashboard
#    - Use Railway PostgreSQL connection string
#    - Set NODE_ENV=production
#
# 4. VALIDATION:
#    - Ensure jwt secrets are at least 32 characters
#    - Ensure Paystack uses live keys for production
#    - Ensure email credentials work (test with password reset)
#    - Ensure DATABASE_URL connects successfully
