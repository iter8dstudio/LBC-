  "item": [
    {
      "name": "AUTH",
      "description": "Authentication endpoints",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save tokens and user ID for later requests",
                  "pm.environment.set(\"ACCESS_TOKEN\", pm.response.json().accessToken);",
                  "pm.environment.set(\"REFRESH_TOKEN\", pm.response.json().refreshToken);",
                  "pm.environment.set(\"USER_ID\", pm.response.json().user.id);",
                  "",
                  "// Assertions",
                  "pm.test(\"Status code is 201\", function() {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has accessToken\", function() {",
                  "  pm.expect(pm.response.json()).to.have.property('accessToken');",
                  "});",
                  "",
                  "pm.test(\"Response has refreshToken\", function() {",
                  "  pm.expect(pm.response.json()).to.have.property('refreshToken');",
                  "});",
                  "",
                  "pm.test(\"Response has user object\", function() {",
                  "  pm.expect(pm.response.json()).to.have.property('user');",
                  "});",
                  "",
                  "pm.test(\"User has email\", function() {",
                  "  pm.expect(pm.response.json().user.email).to.equal('vendor@test.com');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Vendor\",\n  \"email\": \"vendor@test.com\",\n  \"password\": \"SecurePassword123!\",\n  \"phone\": \"+2349012345678\",\n  \"role\": \"VENDOR\"\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/auth/register",
              "host": ["{{API_BASE_URL}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Update tokens from login response",
                  "pm.environment.set(\"ACCESS_TOKEN\", pm.response.json().accessToken);",
                  "pm.environment.set(\"REFRESH_TOKEN\", pm.response.json().refreshToken);",
                  "",
                  "pm.test(\"Status code is 200\", function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains accessToken\", function() {",
                  "  pm.expect(pm.response.json()).to.have.property('accessToken');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"vendor@test.com\",\n  \"password\": \"SecurePassword123!\"\n}"
            },
            "url": {
              "raw": "{{API_BASE_URL}}/auth/login",
              "host": [
                "{{API_BASE_URL}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set(\"ACCESS_TOKEN\", pm.response.json().accessToken);",
                  "  pm.environment.set(\"REFRESH_TOKEN\", pm.response.json().refreshToken);",
                  "}",
                  "",
                  "pm.test(\"Status code is 200\", function() {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
